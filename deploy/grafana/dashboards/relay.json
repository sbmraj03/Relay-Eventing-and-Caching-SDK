{
  "uid": "relay-sdk",
  "title": "Relay SDK",
  "tags": ["relay", "kafka", "redis"],
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Kafka Publish Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(relay_kafka_publishes_total[1m])) by (topic, status)",
          "legendFormat": "{{topic}} / {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Consumer Message Rate (msg/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(relay_consumer_messages_total[1m])) by (topic, group, status)",
          "legendFormat": "{{group}} / {{status}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(relay_cache_operations_total{op=\"hit\"}[5m])) / (sum(rate(relay_cache_operations_total{op=\"hit\"}[5m])) + sum(rate(relay_cache_operations_total{op=\"miss\"}[5m])))",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 4,
      "title": "DLQ Routing Rate (msg/s)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(relay_consumer_dlq_total[1m])) by (topic, group)",
          "legendFormat": "{{topic}} / {{group}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Kafka Publish Latency (p99, ms)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(relay_kafka_publish_duration_seconds_bucket[5m])) by (le, topic)) * 1000",
          "legendFormat": "p99 {{topic}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Cache Load Latency (p99, ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(relay_cache_load_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p99 loader latency"
        }
      ]
    },
    {
      "id": 7,
      "title": "Cache Operations by Type",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(relay_cache_operations_total[1m])) by (op)",
          "legendFormat": "{{op}}"
        }
      ]
    }
  ],
  "schemaVersion": 38
}
